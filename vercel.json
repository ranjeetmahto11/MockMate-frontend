{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://ai-mock-interview-73qo.onrender.com/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}